#!/bin/bash

# Development environment setup script (Unified Entry Point)
# Usage: ./setup
# Detects OS and runs appropriate platform-specific setup, then common configurations

set -euo pipefail

# Get script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source library modules
source "$SCRIPT_DIR/lib/env-loader.sh"
source "$SCRIPT_DIR/lib/os-detect.sh"

echo "🚀 Development Environment Setup"
echo "=================================="

# ============================================================================
# Shared Setup Functions (Cross-platform)
# ============================================================================

_setup_git_identities() {
    echo "Setting up Git identities..."

    # --- Global Git Config ---
    if [ -n "${GIT_USER_NAME:-}" ]; then
        git config --global user.name "$GIT_USER_NAME"
    fi

    if [ -n "${GIT_USER_EMAIL:-}" ]; then
        git config --global user.email "$GIT_USER_EMAIL"
    fi

    if [ -n "${GIT_SSH_SIGNING_KEY:-}" ]; then
        local signing_key_path="${GIT_SSH_SIGNING_KEY/#\~/$HOME}"

        if [ -f "$signing_key_path" ]; then
            echo "Setting up Git SSH signing with key: $signing_key_path"
            git config --global gpg.format ssh
            git config --global user.signingkey "$signing_key_path"
            git config --global commit.gpgsign true
        else
            echo "⚠️  GIT_SSH_SIGNING_KEY provided but file not found: $GIT_SSH_SIGNING_KEY"
            echo "   (Expanded path: $signing_key_path)"
            echo "   Skipping SSH signing configuration."
        fi
    fi

    # --- Git Aliases ---
    echo "Setting up Git aliases..."
    git config --global alias.ai-commit "!bash $HOME/script/ai-commit"
    git config --global alias.ccc "!bash $HOME/script/ai-commit"
    git config --global alias.setup-hook "!bash $HOME/script/setup-git-hook"
    git config --global alias.sss "!bash $HOME/script/setup-git-hook"
    echo "✅ Git aliases setup completed!"

    # --- Global Git Ignore ---
    echo "Setting up global Git ignore..."
    local global_gitignore="$HOME/.gitignore_global"
    git config --global core.excludesfile "$global_gitignore"
    echo "✅ Configured global gitignore to use $global_gitignore"

    # --- Per-directory Git Config ---
    _setup_git_workspace() {
        local workspace_name="$1"

        if [ -z "$workspace_name" ]; then
            echo "❌ Workspace name is required"
            return 1
        fi

        if [[ ! "$workspace_name" =~ ^[a-zA-Z0-9]+$ ]]; then
            echo "❌ Invalid workspace name: '$workspace_name'"
            echo "   Workspace names must contain only: a-z, A-Z, 0-9"
            return 1
        fi

        echo "Setting up workspace: $workspace_name..."
        local workspace_dir="$HOME/repos/$workspace_name"
        mkdir -p "$workspace_dir"

        # workspace git config
        local config_file="$workspace_dir/.gitconfig"
        git config --global includeIf."gitdir:$workspace_dir/".path "$config_file"

        if [ ! -f "$config_file" ]; then
            touch "$config_file"
        fi

        # git email config
        local email_var="GIT_WORKSPACE_${workspace_name}_EMAIL"
        local workspace_email="${!email_var:-}"

        if [ -n "$workspace_email" ]; then
            git config -f "$config_file" user.email "$workspace_email"
        fi

        # nuget config
        local nuget_var="GIT_WORKSPACE_${workspace_name}_NUGET_URL"
        local workspace_nuget_url="${!nuget_var:-}"

        if [ -n "$workspace_nuget_url" ]; then
            local nuget_config="$workspace_dir/NuGet.config"
            if [ -f "$nuget_config" ]; then
                echo "⚠️  $nuget_config already exists, skipping..."
            else
                cat <<-EOF > "$nuget_config"
<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <packageSources>
        <add key="$workspace_name" value="$workspace_nuget_url" protocolVersion="3" />
    </packageSources>
</configuration>
EOF
            fi
        fi
    }

    # Load workspaces from env
    if [ -n "${GIT_WORKSPACES:-}" ]; then
        for workspace in ${GIT_WORKSPACES}; do
            _setup_git_workspace "$workspace"
        done
    fi

    echo "✅ Git identities setup completed!"
}

_setup_zsh() {
    echo "Setting up Oh My Zsh and plugins..."

    # Check if Zsh is installed
    if ! command -v zsh &>/dev/null; then
        echo "⚠️  Zsh is not installed. It should have been installed by the platform setup."
        return 1
    fi

    # Install Oh My Zsh if it's not already installed
    if [ ! -d "$HOME/.oh-my-zsh" ]; then
        echo "Installing Oh My Zsh..."
        sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
    else
        echo "✅ Oh My Zsh is already installed."
    fi

    # Define the custom path for plugins and themes
    ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"

    # Helper function to clone a git repo if the destination directory doesn't exist
    _clone_if_not_exists() {
        local repo_url="$1"
        local dest_path="$2"
        local name="$3"
        if [ ! -d "$dest_path" ]; then
            echo "Installing $name..."
            git clone --depth=1 "$repo_url" "$dest_path"
        else
            echo "✅ $name is already installed."
        fi
    }

    # Install theme and plugins
    _clone_if_not_exists "https://github.com/romkatv/powerlevel10k.git" "${ZSH_CUSTOM}/themes/powerlevel10k" "Powerlevel10k theme"
    _clone_if_not_exists "https://github.com/zsh-users/zsh-syntax-highlighting.git" "${ZSH_CUSTOM}/plugins/zsh-syntax-highlighting" "zsh-syntax-highlighting plugin"
    _clone_if_not_exists "https://github.com/zsh-users/zsh-autosuggestions.git" "${ZSH_CUSTOM}/plugins/zsh-autosuggestions" "zsh-autosuggestions plugin"
    _clone_if_not_exists "https://github.com/TamCore/autoupdate-oh-my-zsh-plugins.git" "${ZSH_CUSTOM}/plugins/autoupdate" "autoupdate-oh-my-zsh-plugins"

    echo "✅ Oh My Zsh and plugins installed."
}

_setup_node() {
    echo "Setting up Node.js (via fnm)..."

    if ! command -v fnm &> /dev/null; then
        echo "❌ fnm not found, cannot install Node.js. Skipping."
        return 1
    fi

    # fnm is the single source of truth for Node (no brew/system node).
    eval "$(fnm env)"

    if ! command -v node &> /dev/null; then
        echo "Installing Node.js LTS via fnm..."
        fnm install --lts
        fnm default lts-latest
        eval "$(fnm env)"
    else
        echo "✅ Node.js already installed ($(node --version))"
    fi
}

_setup_corepack() {
    echo "Enabling Corepack (pnpm/yarn shims)..."

    # Homebrew's `node` formula does not ship corepack; the fnm-managed Node
    # does. Load fnm's env so `corepack` resolves to the fnm Node bin.
    if command -v fnm &> /dev/null; then
        eval "$(fnm env)"
    fi

    if ! command -v corepack &> /dev/null; then
        echo "⚠️  corepack not found (requires Node.js >= 16.9). Skipping."
        return 0
    fi

    # Corepack ships with Node and manages pnpm/yarn versions per-project,
    # so they follow the active Node version instead of a global install.
    corepack enable

    echo "✅ Corepack enabled — run pnpm/yarn directly (auto-downloaded on first use)."
}

_setup_claude_cli() {
    echo "Setting up Claude Code CLI..."

    # Ensure ~/.local/bin is in PATH for the setup script context
    if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
        export PATH="$HOME/.local/bin:$PATH"
    fi

    if command -v claude &>/dev/null; then
        echo "✅ Claude Code CLI (claude) is already installed."
    else
        echo "Installing Claude Code CLI..."
        curl -fsSL https://claude.ai/install.sh | bash
    fi
}

_setup_antigravity_cli() {
    echo "Setting up Antigravity CLI..."

    # Ensure ~/.local/bin is in PATH for the setup script context
    if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
        export PATH="$HOME/.local/bin:$PATH"
    fi

    if command -v agy &>/dev/null; then
        echo "✅ Antigravity CLI (agy) is already installed."
    else
        echo "Installing Antigravity CLI..."
        curl -fsSL https://antigravity.google/cli/install.sh | bash
    fi
}

# ============================================================================
# Main Execution
# ============================================================================

main() {
    local os_name
    os_name=$(detect_os)

    echo "Detected OS: $os_name"
    echo ""

    # Load environment variables
    load_env "$SCRIPT_DIR"

    # Run platform-specific setup
    if is_macos; then
        if [ -f "$SCRIPT_DIR/setup-macos" ]; then
            bash "$SCRIPT_DIR/setup-macos"
        else
            echo "❌ setup-macos not found"
            exit 1
        fi
    elif is_ubuntu; then
        if [ -f "$SCRIPT_DIR/setup-ubuntu" ]; then
            bash "$SCRIPT_DIR/setup-ubuntu"
        else
            echo "❌ setup-ubuntu not found"
            exit 1
        fi
    else
        echo "❌ Unsupported OS: $os_name"
        echo "Supported: macos, ubuntu"
        exit 1
    fi

    # Ensure Homebrew is on PATH for macOS (arm64) after platform setup
    if is_macos && [[ $(uname -m) == "arm64" ]] && [[ ":$PATH:" != *":/opt/homebrew/bin:"* ]]; then
        export PATH="/opt/homebrew/bin:$PATH"
    fi

    # Ensure fnm is on PATH and initialized after platform setup (Ubuntu)
    if is_ubuntu; then
        export PATH="$HOME/.local/share/fnm:$PATH"
        if command -v fnm &>/dev/null; then
            eval "$(fnm env)"
        fi
    fi

    echo ""
    echo "🔧 Running cross-platform setup..."
    echo ""

    # Run shared setup functions
    _setup_zsh
    _setup_git_identities
    _setup_node
    _setup_corepack
    _setup_claude_cli
    _setup_antigravity_cli

    echo ""
    echo "🎉 All done! Your development environment is ready."
    echo ""
    echo "📝 Next steps:"
    echo "  1. Restart your terminal or run: source ~/.zshrc"
    if is_ubuntu; then
        echo "  2. If you changed default shell to zsh, log out and log back in"
    fi
}

main "$@"
